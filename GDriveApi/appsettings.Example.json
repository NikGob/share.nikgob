{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDb": {
    "ConnectionString": "mongodb://user:password@localhost:27017/",
    "DatabaseName": "gdrive-api"
  },
  "Google": {
    "FolderId": "YOUR_GOOGLE_DRIVE_FOLDER_ID",
    "ClientId": "YOUR_GOOGLE_OAUTH_CLIENT_ID",
    "ClientSecret": "YOUR_GOOGLE_OAUTH_CLIENT_SECRET",
    "RefreshToken": "YOUR_GOOGLE_OAUTH_REFRESH_TOKEN",
    "BaseDownloadUrl": "https://drive.usercontent.google.com/download?id=",
    "ImageDownloadUrl": "https://lh3.googleusercontent.com/d/"
  },
  "Shlink": {
    "BaseUrl": "https://your-shlink-instance.com",
    "ApiKey": "YOUR_SHLINK_API_KEY",
    "Domain": "your-short-domain.com"
  }
}
